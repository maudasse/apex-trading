# ─────────────────────────────────────────────
#  MetaApi Credentials
#  Get these from: https://app.metaapi.cloud
# ─────────────────────────────────────────────

# Your MetaApi token (from MetaApi dashboard → API Access)
META_API_TOKEN=your_metaapi_token_here

# Your MT4 Account ID (from MetaApi dashboard → Accounts)
MT4_ACCOUNT_ID=your_mt4_account_id_here

# Your MT5 Account ID (from MetaApi dashboard → Accounts)
MT5_ACCOUNT_ID=your_mt5_account_id_here

# ─────────────────────────────────────────────
#  Server Config
# ─────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
